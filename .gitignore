*.log
.DS_Store
.env
.env.backup
.env.production
# Every local variant (.env.bak, .env.local, …): only ".env.backup" was listed
# before, so other copies could slip into a commit.
.env.*
!.env.example
.phpactor.json
.phpunit.result.cache
/.fleet
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
/node_modules
# public/build is committed: the shared host has no Node, so deploys ship the
# built assets. Ignoring it let hashed filenames escape git and a `git reset`
# on the server wiped the site's CSS/JS.
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
Homestead.json
Homestead.yaml
Thumbs.db
